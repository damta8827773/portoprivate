# ============================================================
#  Damta Portfolio — environment template
#  Copy to `.env` (root) and `apps/api/.env`, then fill values.
# ============================================================

# ---- MySQL (docker-compose) ----
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=damta_portfolio
MYSQL_USER=damta
MYSQL_PASSWORD=damtapass

# ---- Backend (apps/api) ----
NODE_ENV=development
PORT=4000
# Prisma connection string (matches docker-compose values above)
DATABASE_URL="mysql://damta:damtapass@localhost:3306/damta_portfolio"
# Comma-separated list of allowed origins for CORS
CORS_ORIGIN="http://localhost:5173"
# GitHub username powering the public dashboard
GITHUB_USERNAME=damta8827773
# Optional GitHub token to raise the public API rate limit (read-only)
GITHUB_TOKEN=

# ---- Frontend (apps/web) — must be prefixed with VITE_ ----
VITE_API_BASE_URL="http://localhost:4000/api"
VITE_GITHUB_USERNAME=damta8827773
# Firebase (auth + comments) — reuse existing project or create new
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Spline 3D robot scene
VITE_SPLINE_SCENE_URL="https://prod.spline.design/kZDDjO5HuC9GJUM2/scene.splinecode"

# ---- External dashboard providers (optional, see backend/.env.example) ----
WAKATIME_API_KEY=
CODEWARS_USERNAME=
MONKEYTYPE_USERNAME=
MONKEYTYPE_API_KEY=
UMAMI_BASE_URL=https://api.umami.is/v1/websites
UMAMI_WEBSITE_ID=
UMAMI_API_KEY=

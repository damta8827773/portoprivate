// Prisma schema - Damta Portfolio API
// Datasource: MySQL 8 (see docker-compose.yml)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// Featured projects shown in the #projects grid (first 6 + "see more").
model Project {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  descId    String   @db.Text
  descEn    String   @db.Text
  image     String
  url       String
  featured  Boolean  @default(true) // among the first 6
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([order])
}

/// Achievements / certificates in the #certificates section.
model Certificate {
  id      Int    @id @default(autoincrement())
  slug    String @unique
  titleId String
  titleEn String
  org     String
  year    String
  image   String
  descId  String @db.Text
  descEn  String @db.Text
  order   Int    @default(0)

  @@index([order])
}

/// Tech / tools shown in the two scrolling skill marquees.
model Skill {
  id       Int    @id @default(autoincrement())
  name     String
  image    String
  category String
  level    Int    @default(0)
  row      Int    @default(1) // 1 = top marquee, 2 = bottom marquee
  order    Int    @default(0)

  @@index([row, order])
}

/// Career & education timeline cards.
model TimelineEntry {
  id        Int    @id @default(autoincrement())
  slug      String @unique
  titleId   String
  titleEn   String
  companyId String
  companyEn String
  dateId    String
  dateEn    String
  descId    String @db.Text
  descEn    String @db.Text
  icon      String
  logo      String?
  order     Int    @default(0)

  @@index([order])
}

/// "Journey by year" history items.
model HistoryEntry {
  id     Int    @id @default(autoincrement())
  year   String
  descId String @db.Text
  descEn String @db.Text
  image  String
  order  Int    @default(0)

  @@index([order])
}

/// Country demographics bars in the dashboard.
model CountryStat {
  id         Int    @id @default(autoincrement())
  name       String
  flag       String
  percentage Int
  order      Int    @default(0)

  @@index([order])
}

/// Monthly visitor breakdown (desktop/mobile) for the bar chart.
model VisitorStat {
  id         Int    @id @default(autoincrement())
  month      String
  monthIndex Int    @unique
  desktop    Int    @default(0)
  mobile     Int    @default(0)

  @@index([monthIndex])
}

/// Singleton total-visitor counter (replaces Firebase statistics/visitors).
model VisitorCounter {
  id    Int @id @default(1)
  count Int @default(0)
}

/// Chat-room comments + replies (replaces Firestore "comments").
model Comment {
  id        Int       @id @default(autoincrement())
  name      String
  email     String
  photo     String?
  comment   String    @db.Text
  rating    Int       @default(0)
  parentId  Int?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
  createdAt DateTime  @default(now())

  @@index([parentId])
  @@index([createdAt])
}

/// Contact form submissions.
model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())
}

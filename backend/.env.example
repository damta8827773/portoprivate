NODE_ENV=development
PORT=4000
DATABASE_URL="mysql://damta:damtapass@localhost:3306/damta_portfolio"
CORS_ORIGIN="http://localhost:5173"
GITHUB_USERNAME=damta8827773
GITHUB_TOKEN=

# Owner identity — only this verified email may post replies in the chat room
OWNER_EMAIL=damtafaiz@gmail.com

# Firebase Admin (server-side ID-token verification for comments).
# Get these from Firebase Console → Project Settings → Service Accounts → Generate key.
# Keep the private key on ONE line with literal \n for newlines, wrapped in quotes.
# If left empty: dev decodes tokens without verifying; production disables posting.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---------------------------------------------------------------
# External dashboard providers (all optional).
# Each /api/insights/* endpoint serves sample data while unset, and
# reports "configured": false so the UI can badge it as demo data.
# ---------------------------------------------------------------

# wakatime.com → Settings → Account → Secret API Key (raw key, not base64)
WAKATIME_API_KEY=

# codewars.com username (public API, no key needed)
CODEWARS_USERNAME=

# monkeytype.com → Settings → Ape Keys
MONKEYTYPE_USERNAME=
MONKEYTYPE_API_KEY=

# Umami Cloud → Settings → API Keys, and the website id from its URL
UMAMI_BASE_URL=https://api.umami.is/v1/websites
UMAMI_WEBSITE_ID=
UMAMI_API_KEY=
